---
import { Image } from 'astro:assets';

import WebApplicationsIcon from "assets/img/services/web_applications.svg";
import CustomSoftwareIcon from "assets/img/services/custom_software.svg";
import SystemsIntegrationsIcon from "assets/img/services/systems_integration.svg";
import MobileApplicationsIcon from "assets/img/services/mobile_applications.svg";
import DevopsIcon from "assets/img/services/devops.svg";
import AIMLIcon from "assets/img/services/aiml.svg";
---

<!-- Services Section -->
<section class="py-20 bg-slate-900">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16">
      <div class="inline-flex items-center bg-blue-600/20 border border-blue-500/30 rounded-full px-4 py-2 text-blue-300 text-sm font-medium mb-6">
        💰 Revenue-Generating Solutions
      </div>
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        Software That <span class="text-green-400">Pays for Itself</span> in 6 Months
      </h2>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        Every solution we build is designed to generate measurable ROI through automation, efficiency gains, and revenue optimization.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 md:grid-cols-2 gap-8 mb-16">
      <!-- Custom Software Development -->
      <div class="group bg-slate-800 border border-slate-700 hover:border-blue-500/50 rounded-xl p-8 transition-all duration-300 hover:transform hover:-translate-y-2">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-16 h-16 bg-blue-600/20 rounded-lg flex items-center justify-center group-hover:bg-blue-600/30 transition-colors">
            <Image src={CustomSoftwareIcon} alt="Custom Software Development" class="w-8 h-8" />
          </div>
          <div>
            <h3 class="text-white text-xl font-semibold">Custom Software Development</h3>
            <div class="text-green-400 text-sm font-medium">ROI: 200-400%</div>
          </div>
        </div>
        
        <p class="text-gray-400 mb-6">
          Eliminate manual processes and boost productivity with software built specifically for your business needs.
        </p>
        
        <div class="space-y-3 mb-6">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-gray-300 text-sm">Reduce operational costs by 40-60%</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-gray-300 text-sm">Automate 80% of repetitive tasks</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-gray-300 text-sm">Scale without hiring additional staff</span>
          </div>
        </div>
        
        <div class="bg-slate-700/50 rounded-lg p-4 mb-6">
          <div class="text-sm text-gray-400 mb-1">Average Client Savings:</div>
          <div class="text-2xl font-bold text-green-400">$25K+/month</div>
        </div>
        
        <div class="flex items-center justify-between">
          <a href="/services/custom-software-development" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-medium transition-colors">
            Learn More
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
          <a href="#strategic-consultation" class="inline-flex items-center gap-2 text-green-400 hover:text-green-300 font-medium transition-colors">
            Get Analysis
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
