---
import Layout from '../layouts/Layout.astro';
import NavComponent from '../components/NavComponent.astro';
---

<Layout 
  title="Thank You - Jay Software | Consultation Request Received"
  description="Thank you for requesting a consultation. We'll review your project and contact you within 24 hours to schedule your strategic session."
  robots="noindex, nofollow"
>
  <body>
    <NavComponent />
    
    <!-- Thank You Section -->
    <section class="bg-slate-900 min-h-screen flex items-center pt-20">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center">
          <!-- Success Icon -->
          <div class="mb-8">
            <div class="w-20 h-20 bg-green-500 rounded-full flex items-center justify-center mx-auto mb-6">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
          </div>

          <!-- Main Message -->
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
            Thank You for Your Interest!
          </h1>
          
          <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
            We've received your consultation request and will review your project details within the next 24 hours.
          </p>

          <!-- What Happens Next -->
          <div class="bg-slate-800 rounded-2xl p-8 mb-8 text-left max-w-3xl mx-auto">
            <h2 class="text-2xl font-semibold text-white mb-6 text-center">What Happens Next?</h2>
            
            <div class="space-y-6">
              <div class="flex items-start space-x-4">
                <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <span class="text-white font-semibold text-sm">1</span>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-white mb-2">Project Review (Next 24 Hours)</h3>
                  <p class="text-gray-300">Our team will analyze your requirements and prepare a preliminary ROI assessment.</p>
                </div>
              </div>

              <div class="flex items-start space-x-4">
                <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <span class="text-white font-semibold text-sm">2</span>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-white mb-2">Personal Outreach</h3>
                  <p class="text-gray-300">Cătălin will personally contact you to schedule your strategic consultation call.</p>
                </div>
              </div>

              <div class="flex items-start space-x-4">
                <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <span class="text-white font-semibold text-sm">3</span>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-white mb-2">Strategy Session ($2,500 Value)</h3>
                  <p class="text-gray-300">60-minute deep-dive into your business processes, pain points, and custom software opportunities.</p>
                </div>
              </div>

              <div class="flex items-start space-x-4">
                <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <span class="text-white font-semibold text-sm">4</span>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-white mb-2">Custom Proposal</h3>
                  <p class="text-gray-300">Receive a detailed proposal with projected ROI, timeline, and investment breakdown.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Urgent Project CTA -->
          <div class="bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl p-6 mb-8">
            <h3 class="text-xl font-semibold text-white mb-3">Urgent Project?</h3>
            <p class="text-blue-100 mb-4">Need to speak with us today? Call directly for immediate attention.</p>
            <a href="tel:+40757123456" class="inline-flex items-center bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              Call Now
            </a>
          </div>

          <!-- Additional Resources -->
          <div class="text-center">
            <p class="text-gray-400 mb-6">While you wait, explore our resources:</p>
            <div class="flex flex-wrap justify-center gap-4">
              <a href="/case-studies" class="bg-slate-800 text-white px-6 py-3 rounded-lg hover:bg-slate-700 transition-colors">
                View Case Studies
              </a>
              <a href="/resources/roi-calculator" class="bg-slate-800 text-white px-6 py-3 rounded-lg hover:bg-slate-700 transition-colors">
                ROI Calculator
              </a>
              <a href="/blog" class="bg-slate-800 text-white px-6 py-3 rounded-lg hover:bg-slate-700 transition-colors">
                Latest Insights
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer Scripts -->
    <script src="/assets/js/bootstrap.bundle.min.js"></script>
  </body>
</Layout> 