---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
---

<Layout 
  title="About Jay Software | Expert Custom Software Development Team"
  description="Meet the team behind Jay Software. Founded by Cătălin Căsunean in Romania, we specialize in ROI-driven custom software solutions that transform business operations into revenue engines."
  keywords="about jay software, custom software team, catalin casuneanu, romania software development, business automation experts"
  canonicalUrl="https://jay-software.com/about"
>
  
  <main class="min-h-screen bg-slate-900">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-blue-900/20 to-purple-900/20 border-b border-slate-700">
