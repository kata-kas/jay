---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import MarqueeComponent from "../components/MarqueeComponent.astro";
import ServicesComponent from "../components/ServicesComponent.astro";

import ConeImage from "assets/img/home-3/cone.webp";
import DonutImage from "assets/img/home-3/donut.webp";
import CirkusLogo from "assets/img/partners/cirkus-logo.svg";
import BMWLogo from "assets/img/partners/bmw-group.svg";
import PluriaLogo from "assets/img/partners/logo-pluria.svg";
import BrightPinkLogo from "assets/img/partners/bright-se-logo.svg";
import JBALogo from "assets/img/partners/jba-group-logo.svg";
import ScrollDownIcon from "assets/img/icons/scroll_down.svg";
import ArrowUpIcon from "assets/img/icons/arrow_up.svg";
---

<Layout 
  title="Custom Software Development | Jay Software - ROI-Driven Solutions"
  description="Stop losing $10K+/month to inefficient systems. Custom software that increases revenue 40-200% within 6 months. Get your strategic consultation today - $2,500 value."
  keywords="custom software development, business automation, ROI software, digital transformation, process optimization, revenue growth software, system integration"
  canonicalUrl="https://jay-software.com/"
>
  <!-- Hero Section - Lead Generation Focused -->
  <section class="hero-section bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 min-h-screen flex items-center relative overflow-hidden">
    <!-- Background Elements -->
    <div class="absolute inset-0 bg-[url('/assets/img/grid-pattern.svg')] opacity-10"></div>
    
    <div class="container mx-auto px-6 py-20 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left Column - Main Content -->
        <div class="text-white space-y-8">
          <!-- Attention-Grabbing Headline -->
          <div class="space-y-4">
            <div class="inline-flex items-center bg-blue-600/20 border border-blue-500/30 rounded-full px-4 py-2 text-blue-300 text-sm font-medium">
              🚀 Trusted by 50+ Growing Businesses
            </div>
            <h1 class="text-4xl lg:text-6xl font-bold leading-tight">
              Stop Losing <span class="text-red-400">$10K+/Month</span> to 
              <span class="bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
                Inefficient Systems
              </span>
            </h1>
            <p class="text-xl lg:text-2xl text-gray-300 leading-relaxed">
              Custom software that <strong class="text-white">actually increases your revenue</strong> by 40-200% within 6 months. No generic solutions. No endless delays.
            </p>
          </div>

          <!-- Value Propositions -->
          <div class="grid md:grid-cols-3 gap-6">
            <div class="text-center md:text-left">
              <div class="text-3xl font-bold text-green-400">2x</div>
              <div class="text-sm text-gray-400">Revenue Increase</div>
            </div>
            <div class="text-center md:text-left">
              <div class="text-3xl font-bold text-blue-400">6 Months</div>
              <div class="text-sm text-gray-400">Average ROI Timeline</div>
            </div>
            <div class="text-center md:text-left">
              <div class="text-3xl font-bold text-purple-400">50+</div>
              <div class="text-sm text-gray-400">Happy Clients</div>
            </div>
          </div>

          <!-- Primary CTA -->
          <div class="space-y-4">
            <a href="#strategic-consultation" 
               class="inline-flex items-center gap-3 bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white px-8 py-4 rounded-lg text-lg font-semibold transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl">
              Request Strategic Revenue Assessment
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </a>
            <p class="text-sm text-gray-400">
              ⚡ <strong>Exclusive Access:</strong> Limited to 3 qualified companies monthly | 
              📞 Executive consultation required | 
              💰 $2,500 value - complimentary for qualified prospects
            </p>
          </div>

          <!-- Trust Indicators -->
          <div class="flex flex-wrap items-center gap-6 pt-4">
            <div class="flex items-center gap-2">
              <div class="flex text-yellow-400">
                ★★★★★
              </div>
              <span class="text-sm text-gray-400">4.9/5 on Google</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-sm text-gray-400">100% Money-Back Guarantee</span>
            </div>
          </div>
        </div>

        <!-- Right Column - Visual Elements -->
        <div class="relative">
          <div class="relative z-10 bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8">
            <h3 class="text-white text-xl font-semibold mb-4">Executive Strategy Session Includes:</h3>
            <ul class="space-y-3 text-gray-300">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                Comprehensive system efficiency analysis
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                Revenue opportunity identification ($50K+ potential)
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                Custom digital transformation roadmap
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                Strategic implementation timeline ($2,500 consulting value)
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof Section -->
  <section class="py-20 bg-slate-900 border-y border-slate-700">
    <div class="container mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-white text-sm font-medium tracking-wider uppercase mb-4">Trusted by Leading Companies</h2>
        <p class="text-gray-400 text-lg">Join 50+ businesses that have transformed their operations with our solutions</p>
      </div>
      
      <MarqueeComponent>
        <div class="flex items-center justify-center bg-slate-800/50 backdrop-blur-sm border border-slate-600/30 rounded-xl px-8 py-6 hover:bg-slate-700/50 hover:border-slate-500/50 transition-all duration-300 group">
          <Image src={BMWLogo} alt="BMW Group - Automotive Industry" class="h-10 max-w-[120px] object-contain filter brightness-110 contrast-110 opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300" />
        </div>
        
        <div class="flex items-center justify-center bg-slate-800/50 backdrop-blur-sm border border-slate-600/30 rounded-xl px-8 py-6 hover:bg-slate-700/50 hover:border-slate-500/50 transition-all duration-300 group">
          <Image src={CirkusLogo} alt="Cirkus - Task Management Software" class="h-10 max-w-[120px] object-contain filter brightness-110 contrast-110 opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300" />
        </div>
        
        <div class="flex items-center justify-center bg-slate-800/50 backdrop-blur-sm border border-slate-600/30 rounded-xl px-8 py-6 hover:bg-slate-700/50 hover:border-slate-500/50 transition-all duration-300 group">
          <Image src={PluriaLogo} alt="Pluria - Coworking Management Software" class="h-10 max-w-[120px] object-contain filter brightness-110 contrast-110 opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300" />
        </div>
        
        <div class="flex items-center justify-center bg-slate-800/50 backdrop-blur-sm border border-slate-600/30 rounded-xl px-8 py-6 hover:bg-slate-700/50 hover:border-slate-500/50 transition-all duration-300 group">
          <Image src={BrightPinkLogo} alt="Bright Pink Agency - Marketing Agency" class="h-10 max-w-[120px] object-contain filter brightness-110 contrast-110 opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300" />
        </div>
        
        <div class="flex items-center justify-center bg-slate-800/50 backdrop-blur-sm border border-slate-600/30 rounded-xl px-8 py-6 hover:bg-slate-700/50 hover:border-slate-500/50 transition-all duration-300 group">
          <Image src={JBALogo} alt="JBA - Mapping and Flood Risk Management" class="h-10 max-w-[120px] object-contain filter brightness-110 contrast-110 opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300" />
        </div>
      </MarqueeComponent>
      
      <!-- Stats Row -->
      <div class="grid md:grid-cols-3 gap-8 mt-16 pt-16 border-t border-slate-700">
        <div class="text-center">
          <div class="text-3xl font-bold text-green-400 mb-2">50+</div>
          <div class="text-gray-400">Successful Projects</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-blue-400 mb-2">200%</div>
          <div class="text-gray-400">Average ROI Increase</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-purple-400 mb-2">6 Months</div>
          <div class="text-gray-400">Average Payback Period</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem/Solution Section -->
  <section class="py-20 bg-slate-800">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
          Are These <span class="text-red-400">Expensive Problems</span> Killing Your Growth?
        </h2>
        <p class="text-xl text-gray-300">
          Most businesses lose $10K-50K monthly due to these hidden revenue killers...
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        <!-- Problem Cards -->
        <div class="bg-slate-900 border border-red-500/20 rounded-xl p-6 hover:border-red-500/40 transition-colors">
          <div class="text-red-400 text-2xl mb-4">💸</div>
          <h3 class="text-white text-lg font-semibold mb-3">Manual Processes Eating Profits</h3>
          <p class="text-gray-400 text-sm">Your team spends 40+ hours/week on tasks that could be automated, costing you $8K+ monthly in wasted labor.</p>
        </div>

        <div class="bg-slate-900 border border-red-500/20 rounded-xl p-6 hover:border-red-500/40 transition-colors">
          <div class="text-red-400 text-2xl mb-4">🐌</div>
          <h3 class="text-white text-lg font-semibold mb-3">Slow, Outdated Systems</h3>
          <p class="text-gray-400 text-sm">Legacy software slowing down operations by 60%, causing customer frustration and lost sales opportunities.</p>
        </div>

        <div class="bg-slate-900 border border-red-500/20 rounded-xl p-6 hover:border-red-500/40 transition-colors">
          <div class="text-red-400 text-2xl mb-4">📊</div>
          <h3 class="text-white text-lg font-semibold mb-3">Data Scattered Everywhere</h3>
          <p class="text-gray-400 text-sm">Critical business insights buried in disconnected systems, preventing data-driven decisions worth $15K+ monthly.</p>
        </div>

        <div class="bg-slate-900 border border-red-500/20 rounded-xl p-6 hover:border-red-500/40 transition-colors">
          <div class="text-red-400 text-2xl mb-4">🔒</div>
          <h3 class="text-white text-lg font-semibold mb-3">Security Vulnerabilities</h3>
          <p class="text-gray-400 text-sm">Outdated systems exposing your business to cyber threats that could cost $100K+ in breaches and downtime.</p>
        </div>

        <div class="bg-slate-900 border border-red-500/20 rounded-xl p-6 hover:border-red-500/40 transition-colors">
          <div class="text-red-400 text-2xl mb-4">😤</div>
          <h3 class="text-white text-lg font-semibold mb-3">Customer Experience Issues</h3>
          <p class="text-gray-400 text-sm">Clunky interfaces and slow processes frustrating customers, leading to 30% higher churn rates.</p>
        </div>

        <div class="bg-slate-900 border border-red-500/20 rounded-xl p-6 hover:border-red-500/40 transition-colors">
          <div class="text-red-400 text-2xl mb-4">⚖️</div>
          <h3 class="text-white text-lg font-semibold mb-3">Scaling Roadblocks</h3>
          <p class="text-gray-400 text-sm">Current systems can't handle growth, forcing you to choose between expansion and operational stability.</p>
        </div>
      </div>

      <!-- Solution CTA -->
      <div class="text-center">
        <h3 class="text-2xl font-bold text-white mb-4">
          Stop the Bleeding. <span class="text-green-400">Start Growing.</span>
        </h3>
        <a href="#strategic-consultation" 
           class="inline-flex items-center gap-3 bg-gradient-to-r from-green-600 to-blue-600 hover:from-green-700 hover:to-blue-700 text-white px-8 py-4 rounded-lg text-lg font-semibold transition-all duration-300 transform hover:scale-105 shadow-lg">
          Request Executive Strategy Session
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <ServicesComponent />

  <!-- Results/Case Studies Section -->
  <section class="py-20 bg-slate-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
          Real Results from Real Clients
        </h2>
        <p class="text-xl text-gray-300">
          See how we've helped businesses like yours increase revenue by 40-200%
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 mb-16">
        <!-- Case Study 1 -->
        <div class="bg-gradient-to-br from-blue-900/20 to-purple-900/20 border border-blue-500/20 rounded-xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <img src="https://media.licdn.com/dms/image/C4E03AQFtmQ-s-UaCXA/profile-displayphoto-shrink_200_200/0/1646644885477?e=2147483647&v=beta&t=kyMbSH2BkvZ774yIm_hnrDCjcqIZNsCxaowJ0FAPIMw" 
                 alt="Tomasz Kornas" class="w-16 h-16 rounded-full" />
            <div>
              <h4 class="text-white font-semibold">Tomasz Kornas</h4>
              <p class="text-gray-400">CEO, Seeking Greatness</p>
            </div>
          </div>
          <blockquote class="text-lg text-gray-300 mb-6">
            "Jay Software delivered exactly what we needed, on time and within budget. The custom solution increased our operational efficiency by 85% and reduced manual work by 12 hours per day."
          </blockquote>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div>
              <div class="text-2xl font-bold text-green-400">85%</div>
              <div class="text-sm text-gray-400">Efficiency Increase</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-blue-400">12hrs</div>
              <div class="text-sm text-gray-400">Daily Time Saved</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-purple-400">$25K</div>
              <div class="text-sm text-gray-400">Monthly Savings</div>
            </div>
          </div>
        </div>

        <!-- Case Study 2 -->
        <div class="bg-gradient-to-br from-green-900/20 to-blue-900/20 border border-green-500/20 rounded-xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <img src="https://media.licdn.com/dms/image/D5603AQGjkoZbXTM5Kg/profile-displayphoto-shrink_400_400/0/1710053572776?e=2147483647&v=beta&t=ClsAQVPEnlU4Dtw78oct7QqaHB1YsBkc1JODGlgB3u8" 
                 alt="Matei A." class="w-16 h-16 rounded-full" />
            <div>
              <h4 class="text-white font-semibold">Matei A.</h4>
              <p class="text-gray-400">CEO, Optico AI</p>
            </div>
          </div>
          <blockquote class="text-lg text-gray-300 mb-6">
            "The team provided valuable insights throughout development. Our new system handles 5x more data processing and improved customer satisfaction by 60%."
          </blockquote>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div>
              <div class="text-2xl font-bold text-green-400">5x</div>
              <div class="text-sm text-gray-400">Data Processing</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-blue-400">60%</div>
              <div class="text-sm text-gray-400">Customer Satisfaction</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-purple-400">40%</div>
              <div class="text-sm text-gray-400">Revenue Growth</div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Add Review Schema for SEO -->
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "Organization",
          "name": "Jay Software",
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.9",
            "reviewCount": "25",
            "bestRating": "5",
            "worstRating": "1"
          },
          "review": [
            {
              "@type": "Review",
              "author": {
                "@type": "Person",
                "name": "Tomasz Kornas"
              },
              "reviewRating": {
                "@type": "Rating",
                "ratingValue": "5",
                "bestRating": "5"
              },
              "reviewBody": "Jay Software delivered exactly what we needed, on time and within budget. The custom solution increased our operational efficiency by 85% and reduced manual work by 12 hours per day.",
              "datePublished": "2024-10-15"
            },
            {
              "@type": "Review",
              "author": {
                "@type": "Person",
                "name": "Matei A."
              },
              "reviewRating": {
                "@type": "Rating",
                "ratingValue": "5",
                "bestRating": "5"
              },
              "reviewBody": "The team provided valuable insights throughout development. Our new system handles 5x more data processing and improved customer satisfaction by 60%.",
              "datePublished": "2024-11-02"
            }
          ]
        }
      </script>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20 bg-slate-800">
    <div class="container mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
          Our Proven 4-Step <span class="text-green-400">Revenue Recovery</span> Process
        </h2>
        <p class="text-xl text-gray-300">
          From bleeding money to generating profit in just 90 days
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="bg-blue-600 w-16 h-16 rounded-full flex items-center justify-center text-white text-xl font-bold mb-4 mx-auto">1</div>
          <h3 class="text-white text-lg font-semibold mb-3">Audit & Discovery</h3>
          <p class="text-gray-400 text-sm">We analyze your current systems and identify exactly where you're losing money (worth $2,500 alone).</p>
        </div>

        <div class="text-center">
          <div class="bg-purple-600 w-16 h-16 rounded-full flex items-center justify-center text-white text-xl font-bold mb-4 mx-auto">2</div>
          <h3 class="text-white text-lg font-semibold mb-3">Custom Strategy</h3>
          <p class="text-gray-400 text-sm">We design a tailored solution that addresses your specific pain points and revenue leaks.</p>
        </div>

        <div class="text-center">
          <div class="bg-green-600 w-16 h-16 rounded-full flex items-center justify-center text-white text-xl font-bold mb-4 mx-auto">3</div>
          <h3 class="text-white text-lg font-semibold mb-3">Rapid Development</h3>
          <p class="text-gray-400 text-sm">We build and deploy your solution in 30-90 days using our proven development methodology.</p>
        </div>

        <div class="text-center">
          <div class="bg-yellow-600 w-16 h-16 rounded-full flex items-center justify-center text-white text-xl font-bold mb-4 mx-auto">4</div>
          <h3 class="text-white text-lg font-semibold mb-3">Growth & Optimization</h3>
          <p class="text-gray-400 text-sm">We monitor results and continuously optimize to maximize your ROI and revenue growth.</p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="#strategic-consultation" 
           class="inline-flex items-center gap-3 bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white px-8 py-4 rounded-lg text-lg font-semibold transition-all duration-300 transform hover:scale-105 shadow-lg">
          Begin Strategic Assessment
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-slate-800">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
            Frequently Asked Questions
          </h2>
          <p class="text-xl text-gray-300">
            Get answers to the most common questions about custom software development
          </p>
        </div>

        <div class="space-y-6">
          <div class="bg-slate-900 border border-slate-700 rounded-xl overflow-hidden">
            <button class="faq-toggle w-full text-left p-6 hover:bg-slate-800 transition-colors" type="button">
              <div class="flex justify-between items-center">
                <h3 class="text-lg font-semibold text-white">How quickly can you deliver a custom software solution?</h3>
                <svg class="faq-icon w-6 h-6 text-gray-400 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </div>
            </button>
            <div class="faq-content hidden px-6 pb-6">
              <p class="text-gray-300">Most projects are completed in 30-90 days depending on complexity. We use agile development methodology with weekly progress updates, so you can see results immediately and start benefiting from improved processes within the first month.</p>
            </div>
