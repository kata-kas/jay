---
import Layout from '../layouts/Layout.astro';
import NavComponent from '../components/NavComponent.astro';
---

<Layout 
  title="Welcome to Jay Software Insights | Newsletter Subscription Confirmed"
  description="Thank you for subscribing to Jay Software insights. You'll receive actionable software development strategies and ROI optimization tips."
  robots="noindex, nofollow"
>
  <body>
    <NavComponent />
    
    <!-- Thank You Section -->
    <section class="bg-slate-900 min-h-screen flex items-center pt-20">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center">
          <!-- Success Icon -->
          <div class="mb-8">
            <div class="w-20 h-20 bg-blue-500 rounded-full flex items-center justify-center mx-auto mb-6">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M3 8l4 4L19 7"></path>
              </svg>
            </div>
          </div>

          <!-- Main Message -->
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
            Welcome to Jay Software Insights!
          </h1>
          
          <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
            You're now subscribed to receive exclusive insights on custom software development, automation strategies, and ROI optimization.
          </p>

          <!-- What You'll Receive -->
          <div class="bg-slate-800 rounded-2xl p-8 mb-8 text-left max-w-3xl mx-auto">
            <h2 class="text-2xl font-semibold text-white mb-6 text-center">What You'll Receive</h2>
            
            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-4">
                <div class="flex items-start space-x-3">
                  <div class="w-6 h-6 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold text-white mb-1">Weekly Insights</h3>
                    <p class="text-gray-300 text-sm">Strategic software development tips and industry trends</p>
                  </div>
                </div>

                <div class="flex items-start space-x-3">
                  <div class="w-6 h-6 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold text-white mb-1">ROI Case Studies</h3>
                    <p class="text-gray-300 text-sm">Real client results with detailed implementation strategies</p>
                  </div>
                </div>

                <div class="flex items-start space-x-3">
                  <div class="w-6 h-6 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold text-white mb-1">Automation Guides</h3>
                    <p class="text-gray-300 text-sm">Step-by-step process optimization frameworks</p>
                  </div>
                </div>
              </div>

              <div class="space-y-4">
                <div class="flex items-start space-x-3">
                  <div class="w-6 h-6 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold text-white mb-1">Exclusive Tools</h3>
                    <p class="text-gray-300 text-sm">Free calculators, templates, and assessment frameworks</p>
                  </div>
                </div>

                <div class="flex items-start space-x-3">
                  <div class="w-6 h-6 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold text-white mb-1">Early Access</h3>
                    <p class="text-gray-300 text-sm">First to know about new services and special offers</p>
                  </div>
                </div>

                <div class="flex items-start space-x-3">
                  <div class="w-6 h-6 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold text-white mb-1">No Spam Promise</h3>
                    <p class="text-gray-300 text-sm">Only valuable content, unsubscribe anytime</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- First Email CTA -->
          <div class="bg-gradient-to-r from-green-600 to-blue-600 rounded-2xl p-6 mb-8">
            <h3 class="text-xl font-semibold text-white mb-3">Check Your Email!</h3>
            <p class="text-green-100 mb-4">Your first insight email is on its way. Don't forget to check your spam folder and add us to your contacts.</p>
            <div class="flex flex-wrap justify-center gap-3">
              <a href="mailto:hello@jay-software.com" class="inline-flex items-center bg-white text-green-600 px-4 py-2 rounded-lg font-semibold hover:bg-gray-100 transition-colors text-sm">
                Add to Contacts
              </a>
              <a href="/resources/roi-calculator" class="inline-flex items-center bg-green-700 text-white px-4 py-2 rounded-lg font-semibold hover:bg-green-800 transition-colors text-sm">
                Try ROI Calculator
              </a>
            </div>
          </div>

          <!-- Immediate Value -->
          <div class="text-center">
            <p class="text-gray-400 mb-6">Start exploring immediately:</p>
            <div class="grid md:grid-cols-3 gap-4 max-w-2xl mx-auto">
              <a href="/case-studies" class="bg-slate-800 text-white p-4 rounded-lg hover:bg-slate-700 transition-colors">
                <svg class="w-8 h-8 text-blue-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
                <h4 class="font-semibold mb-1">Case Studies</h4>
                <p class="text-sm text-gray-400">Real ROI examples</p>
              </a>
              
              <a href="/resources/automation-guides" class="bg-slate-800 text-white p-4 rounded-lg hover:bg-slate-700 transition-colors">
                <svg class="w-8 h-8 text-green-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                </svg>
                <h4 class="font-semibold mb-1">Automation Guides</h4>
                <p class="text-sm text-gray-400">Free frameworks</p>
              </a>
              
              <a href="/about" class="bg-slate-800 text-white p-4 rounded-lg hover:bg-slate-700 transition-colors">
                <svg class="w-8 h-8 text-purple-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                <h4 class="font-semibold mb-1">Our Story</h4>
                <p class="text-sm text-gray-400">Meet the team</p>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer Scripts -->
    <script src="/assets/js/bootstrap.bundle.min.js"></script>
  </body>
</Layout> 