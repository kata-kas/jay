---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Performance Studies | Jay Software - Data-Driven Business Insights">
  <main class="min-h-screen bg-slate-900">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-amber-900/20 to-orange-900/20 border-b border-slate-700">
      <div class="container mx-auto px-6 py-20">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 bg-amber-600/20 border border-amber-500/30 rounded-full px-4 py-2 text-amber-300 text-sm font-medium mb-6">
            📊 Performance Studies
          </div>
          <h1 class="text-4xl lg:text-6xl font-bold text-white mb-6">
            Data-Driven
            <span class="bg-gradient-to-r from-amber-400 to-orange-400 bg-clip-text text-transparent">
              Performance Insights
            </span>
          </h1>
          <p class="text-xl text-gray-300 max-w-3xl mx-auto mb-8">
            Comprehensive analysis of how custom software solutions impact business performance across industries, based on real client data and industry benchmarks.
          </p>
        </div>
      </div>
    </section>

    <!-- Executive Summary -->
    <section class="py-20 bg-slate-900">
      <div class="container mx-auto px-6">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-white mb-12 text-center">Executive Summary</h2>
          
          <div class="grid lg:grid-cols-4 gap-8 mb-16">
            <div class="bg-slate-800 border border-amber-500/20 rounded-xl p-6 text-center">
              <div class="text-3xl font-bold text-amber-400 mb-2">267%</div>
              <div class="text-sm text-gray-300">Average ROI</div>
              <div class="text-xs text-gray-500 mt-2">Across all projects</div>
            </div>
            <div class="bg-slate-800 border border-green-500/20 rounded-xl p-6 text-center">
              <div class="text-3xl font-bold text-green-400 mb-2">78%</div>
              <div class="text-sm text-gray-300">Time Reduction</div>
              <div class="text-xs text-gray-500 mt-2">In manual processes</div>
            </div>
            <div class="bg-slate-800 border border-blue-500/20 rounded-xl p-6 text-center">
              <div class="text-3xl font-bold text-blue-400 mb-2">42%</div>
              <div class="text-sm text-gray-300">Cost Reduction</div>
              <div class="text-xs text-gray-500 mt-2">Operational expenses</div>
            </div>
            <div class="bg-slate-800 border border-purple-500/20 rounded-xl p-6 text-center">
              <div class="text-3xl font-bold text-purple-400 mb-2">5.8 months</div>
              <div class="text-sm text-gray-300">Payback Period</div>
              <div class="text-xs text-gray-500 mt-2">Average break-even</div>
            </div>
          </div>

          <!-- Key Findings -->
          <div class="bg-slate-800 border border-slate-700 rounded-xl p-8">
            <h3 class="text-xl font-bold text-white mb-6">Key Performance Findings</h3>
            
            <div class="grid md:grid-cols-2 gap-8">
              <div>
                <h4 class="text-amber-400 font-semibold mb-4">Productivity Gains</h4>
                <ul class="space-y-3 text-sm text-gray-300">
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-green-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <span>Employee productivity increased by average of 45%</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-green-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <span>Data processing speed improved by 340%</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-green-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <span>Error rates decreased by 89% on average</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-green-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <span>Customer response time improved by 67%</span>
                  </li>
                </ul>
              </div>
              
              <div>
                <h4 class="text-blue-400 font-semibold mb-4">Financial Impact</h4>
                <ul class="space-y-3 text-sm text-gray-300">
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-green-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <span>Revenue per employee increased by 38%</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-green-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <span>Labor costs reduced by 32% through automation</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-green-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <span>Software licensing costs reduced by 58%</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-green-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <span>Customer acquisition cost dropped by 29%</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Industry Performance Analysis -->
    <section class="py-20 bg-slate-800">
      <div class="container mx-auto px-6">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-white mb-12 text-center">Performance by Industry</h2>
          
          <div class="grid lg:grid-cols-3 gap-8">
            <!-- Manufacturing -->
            <div class="bg-slate-900 border border-slate-700 rounded-xl p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="bg-blue-500/20 w-12 h-12 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 7.172V5L8 4z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-white">Manufacturing</h3>
              </div>
              
              <div class="space-y-4 mb-6">
                <div class="flex justify-between items-center">
                  <span class="text-gray-300 text-sm">Average ROI</span>
                  <span class="text-blue-400 font-bold">320%</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-300 text-sm">Efficiency Gain</span>
                  <span class="text-green-400 font-bold">67%</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-300 text-sm">Cost Reduction</span>
                  <span class="text-purple-400 font-bold">48%</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-300 text-sm">Payback Period</span>
                  <span class="text-amber-400 font-bold">4.2 months</span>
                </div>
              </div>
              
              <div class="bg-slate-700/50 p-4 rounded-lg">
                <h4 class="text-blue-400 font-semibold mb-2">Top Performance Drivers</h4>
                <ul class="text-xs text-gray-300 space-y-1">
                  <li>• Automated inventory management</li>
                  <li>• Real-time production monitoring</li>
                  <li>• Predictive maintenance systems</li>
                  <li>• Quality control automation</li>
                </ul>
              </div>
            </div>

            <!-- E-commerce -->
            <div class="bg-slate-900 border border-slate-700 rounded-xl p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="bg-green-500/20 w-12 h-12 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-white">E-commerce</h3>
              </div>
              
              <div class="space-y-4 mb-6">
                <div class="flex justify-between items-center">
                  <span class="text-gray-300 text-sm">Average ROI</span>
                  <span class="text-green-400 font-bold">285%</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-300 text-sm">Order Processing Speed</span>
                  <span class="text-blue-400 font-bold">+412%</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-300 text-sm">Customer Satisfaction</span>
                  <span class="text-purple-400 font-bold">94%</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-300 text-sm">Payback Period</span>
                  <span class="text-amber-400 font-bold">5.1 months</span>
                </div>
              </div>
              
              <div class="bg-slate-700/50 p-4 rounded-lg">
                <h4 class="text-green-400 font-semibold mb-2">Top Performance Drivers</h4>
                <ul class="text-xs text-gray-300 space-y-1">
                  <li>• Automated order fulfillment</li>
                  <li>• Dynamic pricing algorithms</li>
                  <li>• Customer behavior analytics</li>
                  <li>• Inventory optimization</li>
                </ul>
              </div>
            </div>

            <!-- Healthcare -->
            <div class="bg-slate-900 border border-slate-700 rounded-xl p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="bg-purple-500/20 w-12 h-12 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-white">Healthcare</h3>
              </div>
              
              <div class="space-y-4 mb-6">
                <div class="flex justify-between items-center">
                  <span class="text-gray-300 text-sm">Average ROI</span>
                  <span class="text-purple-400 font-bold">225%</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-300 text-sm">Patient Throughput</span>
                  <span class="text-green-400 font-bold">+52%</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-300 text-sm">Administrative Time</span>
                  <span class="text-blue-400 font-bold">-71%</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-300 text-sm">Payback Period</span>
                  <span class="text-amber-400 font-bold">7.3 months</span>
                </div>
              </div>
              
              <div class="bg-slate-700/50 p-4 rounded-lg">
                <h4 class="text-purple-400 font-semibold mb-2">Top Performance Drivers</h4>
                <ul class="text-xs text-gray-300 space-y-1">
                  <li>• Automated patient scheduling</li>
                  <li>• Electronic health records</li>
                  <li>• Billing automation</li>
                  <li>• Telemedicine integration</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Performance Metrics Deep Dive -->
    <section class="py-20 bg-slate-900">
      <div class="container mx-auto px-6">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-white mb-12 text-center">Performance Metrics Analysis</h2>
          
          <div class="grid lg:grid-cols-2 gap-12">
            <!-- Time-to-Value -->
            <div class="bg-slate-800 border border-slate-700 rounded-xl p-8">
              <h3 class="text-xl font-bold text-white mb-6">Time-to-Value Distribution</h3>
              
              <div class="space-y-6">
                <div>
                  <div class="flex justify-between mb-2">
                    <span class="text-gray-300 text-sm">First Week</span>
                    <span class="text-green-400 font-medium">23%</span>
                  </div>
                  <div class="w-full bg-slate-700 rounded-full h-2">
                    <div class="bg-green-400 h-2 rounded-full" style="width: 23%"></div>
                  </div>
                  <p class="text-xs text-gray-400 mt-1">Quick wins through process optimization</p>
                </div>
                
                <div>
                  <div class="flex justify-between mb-2">
                    <span class="text-gray-300 text-sm">Month 1</span>
                    <span class="text-blue-400 font-medium">67%</span>
                  </div>
                  <div class="w-full bg-slate-700 rounded-full h-2">
                    <div class="bg-blue-400 h-2 rounded-full" style="width: 67%"></div>
                  </div>
                  <p class="text-xs text-gray-400 mt-1">Core automation features deployed</p>
                </div>
                
                <div>
                  <div class="flex justify-between mb-2">
                    <span class="text-gray-300 text-sm">Month 3</span>
                    <span class="text-purple-400 font-medium">89%</span>
                  </div>
                  <div class="w-full bg-slate-700 rounded-full h-2">
                    <div class="bg-purple-400 h-2 rounded-full" style="width: 89%"></div>
                  </div>
                  <p class="text-xs text-gray-400 mt-1">Full system integration complete</p>
                </div>
                
                <div>
                  <div class="flex justify-between mb-2">
                    <span class="text-gray-300 text-sm">Month 6</span>
                    <span class="text-amber-400 font-medium">98%</span>
                  </div>
                  <div class="w-full bg-slate-700 rounded-full h-2">
                    <div class="bg-amber-400 h-2 rounded-full" style="width: 98%"></div>
                  </div>
                  <p class="text-xs text-gray-400 mt-1">Maximum ROI achieved with optimizations</p>
                </div>
              </div>
            </div>

            <!-- Cost-Benefit Analysis -->
            <div class="bg-slate-800 border border-slate-700 rounded-xl p-8">
              <h3 class="text-xl font-bold text-white mb-6">Cost vs. Benefit Breakdown</h3>
              
              <div class="space-y-6">
                <div class="bg-green-500/10 border border-green-500/20 rounded-lg p-4">
                  <h4 class="text-green-400 font-semibold mb-3">Annual Benefits</h4>
                  <div class="space-y-2">
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-300">Labor Cost Savings</span>
                      <span class="text-green-400 font-medium">$156,000</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-300">Software License Savings</span>
                      <span class="text-green-400 font-medium">$34,000</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-300">Revenue Increase</span>
                      <span class="text-green-400 font-medium">$89,000</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-300">Error Reduction Savings</span>
                      <span class="text-green-400 font-medium">$23,000</span>
                    </div>
                    <div class="border-t border-green-500/20 pt-2 mt-3">
                      <div class="flex justify-between font-bold">
                        <span class="text-white">Total Annual Benefit</span>
                        <span class="text-green-400">$302,000</span>
                      </div>
                    </div>
                  </div>
                </div>
                
                <div class="bg-blue-500/10 border border-blue-500/20 rounded-lg p-4">
                  <h4 class="text-blue-400 font-semibold mb-3">Investment Costs</h4>
                  <div class="space-y-2">
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-300">Development</span>
                      <span class="text-blue-400 font-medium">$75,000</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-300">Implementation</span>
                      <span class="text-blue-400 font-medium">$15,000</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-300">Training</span>
                      <span class="text-blue-400 font-medium">$8,000</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-300">Annual Maintenance</span>
                      <span class="text-blue-400 font-medium">$12,000</span>
                    </div>
                    <div class="border-t border-blue-500/20 pt-2 mt-3">
                      <div class="flex justify-between font-bold">
                        <span class="text-white">Total Investment</span>
                        <span class="text-blue-400">$110,000</span>
                      </div>
                    </div>
                  </div>
                </div>
                
                <div class="bg-amber-500/10 border border-amber-500/20 rounded-lg p-4 text-center">
                  <div class="text-2xl font-bold text-amber-400 mb-1">275% ROI</div>
                  <div class="text-sm text-gray-300">In Year 1</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Benchmarking -->
    <section class="py-20 bg-slate-800">
      <div class="container mx-auto px-6">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-white mb-12 text-center">Industry Benchmarking</h2>
          
          <div class="bg-slate-900 border border-slate-700 rounded-xl p-8">
            <h3 class="text-xl font-bold text-white mb-8">Custom Software vs. Off-the-Shelf Solutions</h3>
            
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-slate-600">
                    <th class="text-left text-gray-300 pb-4">Metric</th>
                    <th class="text-center text-green-400 pb-4">Custom Software</th>
                    <th class="text-center text-blue-400 pb-4">Off-the-Shelf</th>
                    <th class="text-center text-amber-400 pb-4">Improvement</th>
                  </tr>
                </thead>
                <tbody class="text-gray-300">
                  <tr class="border-b border-slate-700">
                    <td class="py-4">Implementation Time</td>
                    <td class="text-center py-4">8-12 weeks</td>
                    <td class="text-center py-4">12-24 weeks</td>
                    <td class="text-center py-4 text-green-400 font-medium">50% faster</td>
                  </tr>
                  <tr class="border-b border-slate-700">
                    <td class="py-4">Process Fit</td>
                    <td class="text-center py-4">98%</td>
                    <td class="text-center py-4">67%</td>
                    <td class="text-center py-4 text-green-400 font-medium">46% better</td>
                  </tr>
                  <tr class="border-b border-slate-700">
                    <td class="py-4">User Adoption Rate</td>
                    <td class="text-center py-4">92%</td>
                    <td class="text-center py-4">64%</td>
                    <td class="text-center py-4 text-green-400 font-medium">44% higher</td>
                  </tr>
                  <tr class="border-b border-slate-700">
                    <td class="py-4">Annual Licensing Cost</td>
                    <td class="text-center py-4">$8,000</td>
                    <td class="text-center py-4">$45,000</td>
                    <td class="text-center py-4 text-green-400 font-medium">82% lower</td>
                  </tr>
                  <tr class="border-b border-slate-700">
                    <td class="py-4">Customization Level</td>
                    <td class="text-center py-4">100%</td>
                    <td class="text-center py-4">23%</td>
                    <td class="text-center py-4 text-green-400 font-medium">335% more</td>
                  </tr>
                  <tr>
                    <td class="py-4">5-Year TCO</td>
                    <td class="text-center py-4">$156,000</td>
                    <td class="text-center py-4">$284,000</td>
                    <td class="text-center py-4 text-green-400 font-medium">45% lower</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Methodology -->
    <section class="py-20 bg-slate-900">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-white mb-12 text-center">Study Methodology</h2>
          
          <div class="bg-slate-800 border border-slate-700 rounded-xl p-8">
            <div class="grid md:grid-cols-2 gap-8">
              <div>
                <h3 class="text-lg font-semibold text-amber-400 mb-4">Data Collection</h3>
                <ul class="space-y-2 text-sm text-gray-300">
                  <li>• 50+ client implementations analyzed</li>
                  <li>• 18-month performance tracking period</li>
                  <li>• Before/after metrics comparison</li>
                  <li>• Industry benchmark data integration</li>
                  <li>• Third-party validation of results</li>
                </ul>
              </div>
              
              <div>
                <h3 class="text-lg font-semibold text-blue-400 mb-4">Analysis Framework</h3>
