---
import Layout from "../../layouts/Layout.astro";
---

<Layout 
  title="ROI Calculator | Jay Software - Calculate Your Custom Software ROI"
  description="Free interactive ROI calculator for custom software projects. See exactly how much revenue you could generate and costs you could save. Get instant results based on your business data."
  keywords="ROI calculator, software ROI, custom software calculator, business automation ROI, digital transformation calculator, software investment calculator"
  canonicalUrl="https://jay-software.com/resources/roi-calculator"
>
  <main class="min-h-screen bg-slate-900">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-blue-900/20 to-indigo-900/20 border-b border-slate-700">
      <div class="container mx-auto px-6 py-20">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 bg-blue-600/20 border border-blue-500/30 rounded-full px-4 py-2 text-blue-300 text-sm font-medium mb-6">
            🧮 ROI Calculator
          </div>
          <h1 class="text-4xl lg:text-6xl font-bold text-white mb-6">
            Calculate Your
            <span class="bg-gradient-to-r from-blue-400 to-indigo-400 bg-clip-text text-transparent">
              Custom Software ROI
            </span>
          </h1>
          <p class="text-xl text-gray-300 max-w-3xl mx-auto mb-8">
            See exactly how much revenue you could generate and costs you could save with custom software solutions tailored to your business.
          </p>
        </div>
      </div>
    </section>

    <!-- Calculator Section -->
    <section class="py-20 bg-slate-900">
      <div class="container mx-auto px-6">
        <div class="max-w-6xl mx-auto">
          <div class="grid lg:grid-cols-2 gap-12">
            
            <!-- Calculator Form -->
            <div class="bg-slate-800 border border-slate-700 rounded-xl p-8">
              <h2 class="text-2xl font-bold text-white mb-6">Enter Your Business Details</h2>
              
              <form id="roi-calculator" class="space-y-6">
                <!-- Business Size -->
                <div>
                  <label class="block text-white font-medium mb-2">Number of Employees</label>
                  <select id="employees" class="w-full bg-slate-700 text-white border border-slate-600 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                    <option value="10">1-10 employees</option>
                    <option value="25">11-25 employees</option>
                    <option value="50">26-50 employees</option>
                    <option value="100">51-100 employees</option>
                    <option value="250">101-250 employees</option>
                    <option value="500">250+ employees</option>
                  </select>
                </div>

                <!-- Industry -->
                <div>
                  <label class="block text-white font-medium mb-2">Industry</label>
                  <select id="industry" class="w-full bg-slate-700 text-white border border-slate-600 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                    <option value="manufacturing">Manufacturing</option>
                    <option value="ecommerce">E-commerce/Retail</option>
                    <option value="healthcare">Healthcare</option>
                    <option value="finance">Financial Services</option>
                    <option value="professional">Professional Services</option>
                    <option value="technology">Technology</option>
                    <option value="other">Other</option>
                  </select>
                </div>

                <!-- Current Manual Hours -->
                <div>
                  <label class="block text-white font-medium mb-2">Hours spent weekly on manual tasks</label>
                  <input type="range" id="manual-hours" min="5" max="80" value="20" 
                         class="w-full h-2 bg-slate-600 rounded-lg appearance-none cursor-pointer">
                  <div class="flex justify-between text-sm text-gray-400 mt-1">
                    <span>5 hrs</span>
                    <span id="manual-hours-value" class="text-blue-400 font-medium">20 hrs</span>
                    <span>80+ hrs</span>
                  </div>
                </div>

                <!-- Average Hourly Cost -->
                <div>
                  <label class="block text-white font-medium mb-2">Average hourly cost of employee time</label>
                  <div class="relative">
                    <span class="absolute left-3 top-3 text-gray-400">$</span>
                    <input type="number" id="hourly-cost" value="35" min="15" max="200"
                           class="w-full bg-slate-700 text-white border border-slate-600 rounded-lg pl-8 pr-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                  </div>
                </div>

                <!-- Current Software Costs -->
                <div>
                  <label class="block text-white font-medium mb-2">Monthly software/tool costs</label>
                  <div class="relative">
                    <span class="absolute left-3 top-3 text-gray-400">$</span>
                    <input type="number" id="software-costs" value="500" min="0" max="10000"
                           class="w-full bg-slate-700 text-white border border-slate-600 rounded-lg pl-8 pr-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                  </div>
                </div>

                <!-- Revenue Impact -->
                <div>
                  <label class="block text-white font-medium mb-2">Monthly revenue</label>
                  <div class="relative">
                    <span class="absolute left-3 top-3 text-gray-400">$</span>
                    <input type="number" id="monthly-revenue" value="50000" min="1000" max="10000000"
                           class="w-full bg-slate-700 text-white border border-slate-600 rounded-lg pl-8 pr-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                  </div>
                </div>

                <button type="button" onclick="calculateROI()" 
                        class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white py-4 rounded-lg font-semibold transition-all duration-300 transform hover:scale-105">
                  Calculate My ROI
                </button>
              </form>
            </div>

            <!-- Results Panel -->
            <div class="bg-slate-800 border border-slate-700 rounded-xl p-8">
              <h2 class="text-2xl font-bold text-white mb-6">Your Potential ROI</h2>
              
              <div id="results" class="space-y-6">
                <!-- Time Savings -->
                <div class="bg-green-500/10 border border-green-500/20 rounded-lg p-6">
                  <div class="flex items-center gap-3 mb-3">
                    <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <h3 class="text-white font-semibold">Time Savings</h3>
                  </div>
                  <div class="text-3xl font-bold text-green-400 mb-2" id="time-savings">16 hours/week</div>
                  <div class="text-sm text-gray-300" id="time-value">Worth $29,120/year</div>
                </div>

                <!-- Cost Reduction -->
                <div class="bg-blue-500/10 border border-blue-500/20 rounded-lg p-6">
                  <div class="flex items-center gap-3 mb-3">
                    <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                    </svg>
                    <h3 class="text-white font-semibold">Cost Reduction</h3>
                  </div>
                  <div class="text-3xl font-bold text-blue-400 mb-2" id="cost-reduction">$3,000/month</div>
                  <div class="text-sm text-gray-300">Reduced software costs & efficiency gains</div>
                </div>

                <!-- Revenue Increase -->
                <div class="bg-purple-500/10 border border-purple-500/20 rounded-lg p-6">
                  <div class="flex items-center gap-3 mb-3">
                    <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                    </svg>
                    <h3 class="text-white font-semibold">Revenue Increase</h3>
                  </div>
                  <div class="text-3xl font-bold text-purple-400 mb-2" id="revenue-increase">$15,000/month</div>
                  <div class="text-sm text-gray-300">From improved efficiency & automation</div>
                </div>

                <!-- Total ROI -->
                <div class="bg-gradient-to-r from-green-500/20 to-blue-500/20 border border-green-500/30 rounded-lg p-6">
                  <div class="text-center">
                    <h3 class="text-white font-semibold mb-2">Total Annual ROI</h3>
                    <div class="text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-blue-400 mb-2" id="total-roi">280%</div>
                    <div class="text-sm text-gray-300" id="payback-period">Payback in 6 months</div>
                  </div>
                </div>

                <!-- Investment -->
                <div class="bg-slate-700/50 border border-slate-600 rounded-lg p-6">
                  <h3 class="text-white font-semibold mb-3">Estimated Investment</h3>
                  <div class="text-2xl font-bold text-amber-400" id="investment">$25,000 - $45,000</div>
                  <div class="text-sm text-gray-300 mt-2">Based on project complexity and features</div>
                </div>
              </div>

              <!-- CTA -->
              <div class="mt-8 pt-6 border-t border-slate-600">
                <a href="/#strategic-consultation" 
                   class="w-full inline-flex items-center justify-center gap-3 bg-gradient-to-r from-green-600 to-blue-600 hover:from-green-700 hover:to-blue-700 text-white px-8 py-4 rounded-lg text-lg font-semibold transition-all duration-300 transform hover:scale-105 shadow-lg">
                  Get Detailed ROI Analysis
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                  </svg>
                </a>
                <p class="text-center text-sm text-gray-400 mt-3">Free consultation to refine these numbers for your specific situation</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Assumptions Section -->
    <section class="py-16 bg-slate-800">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold text-white mb-8 text-center">Calculation Assumptions</h2>
          <div class="grid md:grid-cols-2 gap-8">
            <div class="space-y-4">
              <h3 class="text-lg font-semibold text-blue-400">Time Savings</h3>
              <ul class="space-y-2 text-sm text-gray-300">
                <li>• 80% reduction in manual tasks through automation</li>
                <li>• Elimination of duplicate data entry</li>
                <li>• Streamlined workflows and processes</li>
                <li>• Real-time data access reducing search time</li>
              </ul>
            </div>
            <div class="space-y-4">
              <h3 class="text-lg font-semibold text-green-400">Revenue Impact</h3>
              <ul class="space-y-2 text-sm text-gray-300">
                <li>• 30% improvement in operational efficiency</li>
                <li>• Better customer experience through automation</li>
                <li>• Data-driven decision making capabilities</li>
                <li>• Scalability without proportional cost increases</li>
              </ul>
            </div>
          </div>
          <div class="mt-8 p-6 bg-amber-500/10 border border-amber-500/20 rounded-lg">
            <p class="text-amber-300 text-sm">
              <strong>Note:</strong> These calculations are estimates based on industry averages and our experience with similar projects. 
              Actual results vary based on implementation quality, business processes, and user adoption. 
              Schedule a consultation for a detailed analysis specific to your business.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    // Update manual hours display
    document.getElementById('manual-hours').addEventListener('input', function(e) {
      document.getElementById('manual-hours-value').textContent = e.target.value + ' hrs';
      calculateROI();
    });

    // Auto-calculate on input changes
    ['employees', 'industry', 'hourly-cost', 'software-costs', 'monthly-revenue'].forEach(id => {
      document.getElementById(id).addEventListener('input', calculateROI);
    });

    function calculateROI() {
      const employees = parseInt(document.getElementById('employees').value);
      const industry = document.getElementById('industry').value;
      const manualHours = parseInt(document.getElementById('manual-hours').value);
      const hourlyCost = parseFloat(document.getElementById('hourly-cost').value);
      const softwareCosts = parseFloat(document.getElementById('software-costs').value);
      const monthlyRevenue = parseFloat(document.getElementById('monthly-revenue').value);

      // Industry multipliers for complexity and ROI
      const industryFactors = {
        manufacturing: { complexity: 1.3, roi: 1.2 },
        ecommerce: { complexity: 1.0, roi: 1.4 },
        healthcare: { complexity: 1.5, roi: 1.1 },
        finance: { complexity: 1.4, roi: 1.3 },
        professional: { complexity: 0.9, roi: 1.1 },
        technology: { complexity: 1.1, roi: 1.2 },
        other: { complexity: 1.0, roi: 1.0 }
      };

      const factor = industryFactors[industry];

      // Calculate time savings (80% of manual work automated)
      const weeklySavings = manualHours * 0.8;
      const annualTimeSavings = weeklySavings * 52 * hourlyCost;

      // Calculate cost reduction (software consolidation + efficiency)
      const monthlyCostReduction = (softwareCosts * 0.6) + (weeklySavings * 4.33 * hourlyCost * 0.3);
      const annualCostReduction = monthlyCostReduction * 12;

      // Calculate revenue increase (efficiency gains)
      const monthlyRevenueIncrease = monthlyRevenue * 0.3 * factor.roi;
      const annualRevenueIncrease = monthlyRevenueIncrease * 12;

      // Calculate investment based on complexity
      const baseInvestment = 25000;
      const complexityMultiplier = (employees / 100) * factor.complexity;
      const investment = baseInvestment + (baseInvestment * complexityMultiplier);

      // Calculate total benefits and ROI
      const totalAnnualBenefit = annualTimeSavings + annualCostReduction + annualRevenueIncrease;
      const roi = ((totalAnnualBenefit - investment) / investment) * 100;
      const paybackMonths = Math.ceil((investment / (totalAnnualBenefit / 12)));

      // Update display
      document.getElementById('time-savings').textContent = weeklySavings.toFixed(0) + ' hours/week';
      document.getElementById('time-value').textContent = 'Worth $' + annualTimeSavings.toLocaleString() + '/year';
      document.getElementById('cost-reduction').textContent = '$' + monthlyCostReduction.toLocaleString() + '/month';
      document.getElementById('revenue-increase').textContent = '$' + monthlyRevenueIncrease.toLocaleString() + '/month';
      document.getElementById('total-roi').textContent = roi.toFixed(0) + '%';
      document.getElementById('payback-period').textContent = 'Payback in ' + paybackMonths + ' months';
      document.getElementById('investment').textContent = '$' + investment.toLocaleString(undefined, {maximumFractionDigits: 0});
    }

    // Initial calculation
    calculateROI();
  </script>
</Layout> 