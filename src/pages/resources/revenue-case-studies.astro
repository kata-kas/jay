---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Revenue Case Studies | Jay Software - Real Results, Real ROI">
  <main class="min-h-screen bg-slate-900">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-green-900/20 to-emerald-900/20 border-b border-slate-700">
      <div class="container mx-auto px-6 py-20">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 bg-green-600/20 border border-green-500/30 rounded-full px-4 py-2 text-green-300 text-sm font-medium mb-6">
            📈 Revenue Case Studies
          </div>
          <h1 class="text-4xl lg:text-6xl font-bold text-white mb-6">
            Real Businesses, Real Results,
            <span class="bg-gradient-to-r from-green-400 to-emerald-400 bg-clip-text text-transparent">
              Real Revenue Growth
            </span>
          </h1>
          <p class="text-xl text-gray-300 max-w-3xl mx-auto mb-8">
            See exactly how our custom software solutions generated measurable ROI for businesses just like yours. Every number is real, every result is verified.
          </p>
        </div>
      </div>
    </section>

    <!-- Filter Section -->
    <section class="py-12 bg-slate-800">
      <div class="container mx-auto px-6">
        <div class="flex flex-wrap justify-center gap-4">
          <button class="bg-green-600 text-white px-6 py-2 rounded-lg font-medium">All Industries</button>
          <button class="bg-slate-700 hover:bg-slate-600 text-gray-300 px-6 py-2 rounded-lg font-medium transition-colors">Manufacturing</button>
          <button class="bg-slate-700 hover:bg-slate-600 text-gray-300 px-6 py-2 rounded-lg font-medium transition-colors">E-commerce</button>
          <button class="bg-slate-700 hover:bg-slate-600 text-gray-300 px-6 py-2 rounded-lg font-medium transition-colors">Healthcare</button>
          <button class="bg-slate-700 hover:bg-slate-600 text-gray-300 px-6 py-2 rounded-lg font-medium transition-colors">Financial Services</button>
          <button class="bg-slate-700 hover:bg-slate-600 text-gray-300 px-6 py-2 rounded-lg font-medium transition-colors">Professional Services</button>
        </div>
      </div>
    </section>

    <!-- Case Studies Grid -->
    <section class="py-20 bg-slate-900">
      <div class="container mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12">
          
          <!-- Case Study 1: Manufacturing -->
          <div class="bg-slate-800 border border-green-500/20 rounded-xl overflow-hidden">
            <div class="bg-gradient-to-r from-green-900/30 to-emerald-900/30 p-6 border-b border-slate-700">
              <div class="flex items-center justify-between mb-4">
                <div class="bg-green-500/20 px-3 py-1 rounded-full text-green-400 text-sm font-medium">Manufacturing</div>
                <div class="text-gray-400 text-sm">12 Months ROI</div>
              </div>
              <h3 class="text-2xl font-bold text-white mb-2">Industrial Equipment Manufacturer</h3>
              <p class="text-gray-300">Custom ERP system replaced 5 different software tools, automated inventory management, and integrated with existing machinery.</p>
            </div>
            
            <div class="p-6">
              <div class="grid grid-cols-3 gap-4 mb-6">
                <div class="text-center">
                  <div class="text-3xl font-bold text-green-400 mb-1">400%</div>
                  <div class="text-sm text-gray-400">ROI Increase</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-bold text-blue-400 mb-1">$45K</div>
                  <div class="text-sm text-gray-400">Monthly Savings</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-bold text-purple-400 mb-1">3 Months</div>
                  <div class="text-sm text-gray-400">Payback Period</div>
                </div>
              </div>
              
              <div class="space-y-4 mb-6">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-sm">Eliminated 30 hours/week of manual data entry</span>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-sm">Reduced inventory holding costs by 35%</span>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-sm">Improved production efficiency by 60%</span>
                </div>
              </div>
              
              <blockquote class="bg-slate-700/50 p-4 rounded-lg border-l-4 border-green-400 mb-6">
                <p class="text-gray-300 italic mb-2">"The custom ERP system transformed our operations. We went from managing 5 different tools to having everything in one place. The ROI was clear within 3 months."</p>
                <cite class="text-green-400 font-medium">— David Chen, Operations Director</cite>
              </blockquote>
              
              <a href="/#strategic-consultation" class="inline-flex items-center gap-2 text-green-400 hover:text-green-300 font-medium transition-colors">
                Get Similar Results
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
              </a>
            </div>
          </div>

          <!-- Case Study 2: E-commerce -->
          <div class="bg-slate-800 border border-blue-500/20 rounded-xl overflow-hidden">
            <div class="bg-gradient-to-r from-blue-900/30 to-cyan-900/30 p-6 border-b border-slate-700">
              <div class="flex items-center justify-between mb-4">
                <div class="bg-blue-500/20 px-3 py-1 rounded-full text-blue-400 text-sm font-medium">E-commerce</div>
                <div class="text-gray-400 text-sm">8 Months ROI</div>
              </div>
              <h3 class="text-2xl font-bold text-white mb-2">Online Retail Store</h3>
              <p class="text-gray-300">Custom inventory management system with automated reordering, dynamic pricing, and integrated customer analytics.</p>
            </div>
            
            <div class="p-6">
              <div class="grid grid-cols-3 gap-4 mb-6">
                <div class="text-center">
                  <div class="text-3xl font-bold text-blue-400 mb-1">250%</div>
                  <div class="text-sm text-gray-400">ROI Increase</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-bold text-green-400 mb-1">90%</div>
                  <div class="text-sm text-gray-400">Error Reduction</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-bold text-purple-400 mb-1">5x</div>
                  <div class="text-sm text-gray-400">Processing Speed</div>
                </div>
              </div>
              
              <div class="space-y-4 mb-6">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-sm">Scaled from 100 to 1000 orders/day</span>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-sm">Automated 80% of inventory decisions</span>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-sm">Increased profit margins by 25%</span>
                </div>
              </div>
              
              <blockquote class="bg-slate-700/50 p-4 rounded-lg border-l-4 border-blue-400 mb-6">
                <p class="text-gray-300 italic mb-2">"The system handles our entire fulfillment process automatically. We've grown 10x without adding staff. It literally runs itself."</p>
                <cite class="text-blue-400 font-medium">— Sarah Martinez, Founder</cite>
              </blockquote>
              
              <a href="/#strategic-consultation" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-medium transition-colors">
                Scale Your Business
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
              </a>
            </div>
          </div>

          <!-- Case Study 3: Healthcare -->
          <div class="bg-slate-800 border border-purple-500/20 rounded-xl overflow-hidden">
            <div class="bg-gradient-to-r from-purple-900/30 to-pink-900/30 p-6 border-b border-slate-700">
              <div class="flex items-center justify-between mb-4">
                <div class="bg-purple-500/20 px-3 py-1 rounded-full text-purple-400 text-sm font-medium">Healthcare</div>
                <div class="text-gray-400 text-sm">6 Months ROI</div>
              </div>
              <h3 class="text-2xl font-bold text-white mb-2">Multi-Location Medical Practice</h3>
              <p class="text-gray-300">Integrated patient management system with automated scheduling, billing, and telemedicine capabilities.</p>
            </div>
            
            <div class="p-6">
              <div class="grid grid-cols-3 gap-4 mb-6">
                <div class="text-center">
                  <div class="text-3xl font-bold text-purple-400 mb-1">280%</div>
                  <div class="text-sm text-gray-400">ROI Increase</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-bold text-green-400 mb-1">95%</div>
                  <div class="text-sm text-gray-400">Patient Satisfaction</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-bold text-blue-400 mb-1">60%</div>
                  <div class="text-sm text-gray-400">Reduced No-Shows</div>
                </div>
              </div>
              
              <div class="space-y-4 mb-6">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-sm">Serve 40% more patients without additional staff</span>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-sm">Automated insurance verification and billing</span>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-sm">Integrated telemedicine increased accessibility</span>
                </div>
              </div>
              
              <blockquote class="bg-slate-700/50 p-4 rounded-lg border-l-4 border-purple-400 mb-6">
                <p class="text-gray-300 italic mb-2">"The system streamlined everything from scheduling to billing. We can focus on patient care instead of paperwork. Patient satisfaction scores have never been higher."</p>
                <cite class="text-purple-400 font-medium">— Dr. Michael Thompson, Practice Owner</cite>
              </blockquote>
              
              <a href="/#strategic-consultation" class="inline-flex items-center gap-2 text-purple-400 hover:text-purple-300 font-medium transition-colors">
                Optimize Your Practice
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
              </a>
            </div>
          </div>

          <!-- Case Study 4: Financial Services -->
          <div class="bg-slate-800 border border-amber-500/20 rounded-xl overflow-hidden">
            <div class="bg-gradient-to-r from-amber-900/30 to-yellow-900/30 p-6 border-b border-slate-700">
              <div class="flex items-center justify-between mb-4">
                <div class="bg-amber-500/20 px-3 py-1 rounded-full text-amber-400 text-sm font-medium">Financial Services</div>
                <div class="text-gray-400 text-sm">4 Months ROI</div>
              </div>
              <h3 class="text-2xl font-bold text-white mb-2">Regional Investment Firm</h3>
              <p class="text-gray-300">AI-powered risk assessment system with automated compliance reporting and client portfolio management.</p>
            </div>
            
            <div class="p-6">
              <div class="grid grid-cols-3 gap-4 mb-6">
                <div class="text-center">
                  <div class="text-3xl font-bold text-amber-400 mb-1">450%</div>
                  <div class="text-sm text-gray-400">ROI Increase</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-bold text-green-400 mb-1">85%</div>
                  <div class="text-sm text-gray-400">Faster Analysis</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-bold text-blue-400 mb-1">99.7%</div>
                  <div class="text-sm text-gray-400">Compliance Rate</div>
                </div>
              </div>
              
              <div class="space-y-4 mb-6">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-sm">Automated risk assessment for 95% of trades</span>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-sm">Real-time compliance monitoring</span>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-400 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-sm">Increased client portfolio performance by 30%</span>
                </div>
              </div>
              
              <blockquote class="bg-slate-700/50 p-4 rounded-lg border-l-4 border-amber-400 mb-6">
                <p class="text-gray-300 italic mb-2">"The AI system identifies opportunities and risks we never would have spotted manually. Our clients' returns have improved significantly while staying compliant."</p>
                <cite class="text-amber-400 font-medium">— Jennifer Wells, Portfolio Manager</cite>
              </blockquote>
              
              <a href="/#strategic-consultation" class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 font-medium transition-colors">
                Boost Performance
