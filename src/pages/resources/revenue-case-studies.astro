    <!-- Summary Stats -->
    <section class="py-20 bg-slate-800">
      <div class="container mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
            The Numbers Don't Lie
          </h2>
          <p class="text-xl text-gray-300">
            Consistent results across industries and business sizes
          </p>
        </div>

        <div class="grid md:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="text-4xl font-bold text-green-400 mb-2">50+</div>
            <div class="text-gray-300">Successful Projects</div>
          </div>
          <div class="text-center">
            <div class="text-4xl font-bold text-blue-400 mb-2">280%</div>
            <div class="text-gray-300">Average ROI</div>
          </div>
          <div class="text-center">
            <div class="text-4xl font-bold text-purple-400 mb-2">6 Months</div>
            <div class="text-gray-300">Average Payback</div>
          </div>
          <div class="text-center">
            <div class="text-4xl font-bold text-amber-400 mb-2">$2.8M</div>
            <div class="text-gray-300">Total Revenue Generated</div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-gradient-to-r from-green-900/20 to-emerald-900/20">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
            Ready to Write Your Own <span class="text-green-400">Success Story</span>?
          </h2>
          <p class="text-xl text-gray-300 mb-8">
            These results aren't accidents. They're the outcome of strategic software solutions designed specifically for revenue growth.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/#strategic-consultation" 
               class="inline-flex items-center gap-3 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white px-8 py-4 rounded-lg text-lg font-semibold transition-all duration-300 transform hover:scale-105 shadow-lg">
              Get Your ROI Analysis
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </a>
            <a href="/resources/roi-calculator" 
               class="inline-flex items-center gap-3 bg-slate-700 hover:bg-slate-600 text-white px-8 py-4 rounded-lg text-lg font-semibold transition-all duration-300">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
