  <script>
    // Simple calculator for the automation assessment
    function updateSavings() {
      const hours = parseFloat(document.getElementById('manual-hours-guide').value) || 0;
      const cost = parseFloat(document.getElementById('hourly-cost-guide').value) || 0;
      const weeklySavings = hours * cost * 0.8; // 80% automation
      const annualSavings = weeklySavings * 52;
      
      document.getElementById('potential-savings').textContent = '$' + annualSavings.toLocaleString();
    }

    // Add event listeners
    document.getElementById('manual-hours-guide').addEventListener('input', updateSavings);
    document.getElementById('hourly-cost-guide').addEventListener('input', updateSavings);

    // Initial calculation
    updateSavings();
  </script>
